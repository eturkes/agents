#!/usr/bin/env bash
set -euo pipefail

# Make pnpm globals reachable when this script runs outside an interactive shell.
export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --- Rust: rustup, toolchains, and cargo-installed CLIs ---
# Update rustup itself, all installed Rust toolchains, and cargo binaries tracked
# by cargo-install-update.
rustup self update
rustup update
cargo install-update -a

# rtk was installed via `cargo binstall --git`, which registers it only in
# ~/.cargo/.crates.toml and not .crates2.json, so cargo-install-update cannot
# see it. Re-run binstall to keep it current from the prebuilt release binary.
cargo binstall -y --git https://github.com/rtk-ai/rtk rtk

# --- Python: uv and uv-managed tools ---
# Update uv itself, then upgrade uv tool/uvx-managed command-line tools.
uv self update
PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1 uv tool upgrade --all

# A resident uvx tool (e.g. the Serena MCP server while any Claude session is
# open) holds the uv cache lock and `uv cache prune` waits on it forever; cap
# the wait and skip pruning in that case rather than hanging the whole run.
timeout 30 uv cache prune || echo "uv cache in use (resident uvx tool); prune skipped"

# --- Node: Corepack, pnpm globals, and lsp-node ---
# pnpm is Corepack-managed; stay on latest v10 while this container uses Node 20.
corepack install -g pnpm@latest-10

# npm is required by Serena's LSP installer, which shells out to `npm install`.
# It lives as a pnpm global rather than in lsp-node, so upgrade it explicitly.
pnpm add -g npm@latest

# ChromiumFish auto-upgrade/fetch is disabled until its Linux release cache is
# self-contained again. The 150.0.7844 archive unpacked without
# chrome_crashpad_handler; the fetcher accepted that partial cache because it
# only checks for the main chrome binary. This machine's cache was manually
# repaired with an existing Chrome-for-Testing crashpad handler, but an
# automatic package upgrade, browser-version bump, clear, or refetch can replace
# it with an unverified/broken cache. Re-enable only after upstream publishes a
# verified Linux archive that includes the handler, or after adding an explicit
# post-fetch repair/validation step here.
# pnpm add -g chromiumfish@latest playwright-core@latest
# chromiumfish fetch

# Keep the lsp-node workspace healthy across pnpm store major-version changes,
# then take dependency updates intentionally for it (turtle-language-server).
CI=true pnpm -C ~/.local/share/lsp-node install
CI=true pnpm -C ~/.local/share/lsp-node update --latest

# Drop unreachable package-store files after global and lsp-node updates.
pnpm store prune

# --- Lean: elan and stable toolchain ---
# Update elan itself, then ensure stable is installed/current.
elan self update

# 'elan toolchain install' exits non-zero when 'stable' already resolves to the
# newest installed release; ignore just that so 'set -e' doesn't abort the run.
out="$(elan toolchain install stable 2>&1)" && rc=0 || rc=$?
printf '%s\n' "$out"
[[ $rc -eq 0 || "$out" == *"already installed"* ]] || exit "$rc"

# --- Pinned LSP binaries: manual upgrades only ---
# lemminx, alloy.jar, dolmen-lsp, egglog-lsp, prolog-lsp, and souffle-lsp are
# pinned manual installs; upgrade each on purpose via its recipe in
# ~/agents/claude/marketplace/plugins/*/README.md. dolmen-lsp is a standalone
# copied binary; its opam toolchain is installed only for a rebuild and removed
# again afterwards (no resident opam to upgrade here). prolog-lsp is pinned to
# lsp_server 3.16.3 deliberately: 3.17.0 regressed initialize for utf-16 clients
# (see its README); re-check upstream before bumping. souffle-lsp is rebuilt
# from source via gradlew.

# --- Codex CLI ---
# Use Codex's own updater for the CLI.
codex update

# --- Docs mirror: agentlanguages.dev/llms.txt ---
# Refresh the local llms.txt copy from upstream on every run. It is git-ignored
# rather than tracked (see .gitignore), since it can always be re-fetched here.
# Download to a temp file first, then move it into place, so an interrupted or
# failed fetch leaves the existing copy intact. A fetch failure is non-fatal:
# warn and keep the current copy rather than aborting the rest of the upgrade.
agentlang_doc="$HOME/agents/docs/agentlanguages.dev/llms.txt"
agentlang_tmp="$(mktemp)"
if curl -fsSL -o "$agentlang_tmp" https://agentlanguages.dev/llms.txt; then
  mv "$agentlang_tmp" "$agentlang_doc"
else
  rm -f "$agentlang_tmp"
  echo "agentlanguages.dev/llms.txt fetch failed; keeping existing copy" >&2
fi
