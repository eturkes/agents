#!/bin/sh
# Claude Code PostToolUse hook: alert once per limit-window when 5h or 7d usage hits 100%.
# Reads the statusline's oauth-usage cache (utilization is a 0-100 %); self-refreshes it in the
# background when stale (>=180s) so long tool-only runs stay current even if the statusline isn't
# rendering. Silent below 100%; on a cross it injects a terse CLOSE-FAST pointer — the response
# protocol lives in CLAUDE.md # Subagents (single source of truth). Paths overridable for testing.
uc="${OAUTH_USAGE_FILE:-$HOME/.claude/.oauth_usage.json}"
cred="${OAUTH_CRED_FILE:-$HOME/.claude/.credentials.json}"
mk="${OAUTH_ALERT_MARK:-$HOME/.claude/.oauth_limit_alerted}"
lk="$uc.lock"
now=$(date +%s)

[ -t 0 ] || cat >/dev/null 2>&1                                  # drain hook stdin (fields unused)
date +%s >"$HOME/.claude/.oauth_limit_alert.stamp" 2>/dev/null   # liveness marker (last run epoch)

# Refresh the cache in the background if stale, mirroring the statusline. Detached => non-blocking.
ca=$(stat -c %Y "$uc" 2>/dev/null || echo 0)
if [ "$(( now - ca ))" -ge 180 ]; then
  lm=$(stat -c %Y "$lk" 2>/dev/null || echo 0)                   # reap a stale lock from a killed fetch
  [ "$lm" -gt 0 ] && [ "$(( now - lm ))" -ge 60 ] && rmdir "$lk" 2>/dev/null
  if mkdir "$lk" 2>/dev/null; then
    setsid -f sh -c '
      t=$(jq -r ".claudeAiOauth.accessToken // empty" "$1" 2>/dev/null)
      if [ -n "$t" ]; then
        r=$(curl -fsS --max-time 8 -H "Authorization: Bearer $t" -H "anthropic-beta: oauth-2025-04-20" https://api.anthropic.com/api/oauth/usage 2>/dev/null)
        [ -n "$r" ] && printf %s "$r" | jq -e .five_hour >/dev/null 2>&1 && printf %s "$r" >"$2.tmp" && mv "$2.tmp" "$2"
      fi
      rmdir "$3" 2>/dev/null
    ' _ "$cred" "$uc" "$lk" </dev/null >/dev/null 2>&1 &
  fi
fi

[ -s "$uc" ] || exit 0
sel=$(jq -r '
  (.five_hour.utilization // 0) as $f | (.seven_day.utilization // 0) as $w |
  if   $f >= 100 and $f >= $w then "5h \(.five_hour.resets_at // "")"
  elif $w >= 100              then "7d \(.seven_day.resets_at // "")"
  else "" end' "$uc" 2>/dev/null)
[ -n "$sel" ] || exit 0                                          # under 100% => silent

win=${sel%% *}; rid=${sel#* }
prev=""; [ -f "$mk" ] && IFS= read -r prev <"$mk" 2>/dev/null
[ "$prev" = "$rid" ] && exit 0                                   # already alerted for this window
printf '%s' "$rid" >"$mk" 2>/dev/null

msg="⚠ USAGE LIMIT at 100% (${win} window; usage credits now billing) → CLOSE-FAST now, per CLAUDE.md # Subagents."
jq -n --arg m "$msg" '{hookSpecificOutput:{hookEventName:"PostToolUse",additionalContext:$m}}'
