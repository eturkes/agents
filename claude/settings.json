{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus[1m]",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(batcat:*)",
      "Bash(ccat:*)",
      "Bash(pygmentize:*)",
      "Bash(highlight:*)",
      "Bash(source-highlight:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(most:*)",
      "Bash(pg:*)",
      "Bash(nl:*)",
      "Bash(tac:*)",
      "Bash(rev:*)",
      "Bash(fold:*)",
      "Bash(pr:*)",
      "Bash(fmt:*)",
      "Bash(od:*)",
      "Bash(xxd:*)",
      "Bash(hexdump:*)",
      "Bash(hd:*)",
      "Bash(hexyl:*)",
      "Bash(strings:*)",
      "Bash(rtk read:*)",
      "Bash(vi:*)",
      "Bash(vim:*)",
      "Bash(nvim:*)",
      "Bash(view:*)",
      "Bash(nano:*)",
      "Bash(emacs:*)",
      "Bash(ed:*)"
    ],
    "defaultMode": "dontAsk"
  },
  "skillOverrides": {
    "claude-api": "off",
    "update-config": "off",
    "schedule": "off",
    "run": "off",
    "loop": "off",
    "verify": "off",
    "keybindings-help": "off",
    "code-review": "off",
    "fewer-permission-prompts": "off",
    "security-review": "off",
    "init": "off",
    "review": "off",
    "simplify": "off",
    "deep-research": "off"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "html-lsp@global": true,
    "json-lsp@global": true,
    "markdown-lsp@global": true
  },
  "extraKnownMarketplaces": {
    "global": {
      "source": {
        "source": "directory",
        "path": "/var/home/eturkes/debian/agents/claude/marketplace"
      }
    }
  },
  "workflowKeywordTriggerEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline",
    "refreshInterval": 60
  },
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "autoCompactEnabled": false,
  "teammateMode": "in-process",
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "useAutoModeDuringPlan": false,
  "switchModelsOnFlag": false
}
