{
  "name": "global",
  "owner": {
    "name": "eturkes",
    "email": "emir.turkes@eturkes.com"
  },
  "metadata": {
    "description": "User-global LSP plugins available across all projects. Server binaries must be present on PATH; see plugin READMEs for install commands."
  },
  "plugins": [
    {
      "name": "html-lsp",
      "description": "HTML LSP via vscode-html-language-server (from vscode-langservers-extracted)",
      "version": "1.0.0",
      "source": "./plugins/html-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "vscode-html": {
          "command": "vscode-html-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".html": "html",
            ".htm": "html"
          }
        }
      }
    },
    {
      "name": "json-lsp",
      "description": "JSON LSP via vscode-json-language-server (from vscode-langservers-extracted)",
      "version": "1.0.0",
      "source": "./plugins/json-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "vscode-json": {
          "command": "vscode-json-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".json": "json",
            ".jsonc": "jsonc"
          }
        }
      }
    },
    {
      "name": "markdown-lsp",
      "description": "Markdown LSP via marksman",
      "version": "1.0.0",
      "source": "./plugins/markdown-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "marksman": {
          "command": "marksman",
          "args": [
            "server"
          ],
          "extensionToLanguage": {
            ".md": "markdown",
            ".markdown": "markdown"
          }
        }
      }
    },
    {
      "name": "pyright-lsp",
      "description": "Python LSP via pyright-langserver (pyright)",
      "version": "1.0.0",
      "source": "./plugins/pyright-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "pyright": {
          "command": "pyright-langserver",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    },
    {
      "name": "yaml-lsp",
      "description": "YAML LSP via yaml-language-server (Red Hat)",
      "version": "1.0.0",
      "source": "./plugins/yaml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "yaml": {
          "command": "yaml-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".yaml": "yaml",
            ".yml": "yaml"
          }
        }
      }
    },
    {
      "name": "toml-lsp",
      "description": "TOML LSP via taplo",
      "version": "1.0.0",
      "source": "./plugins/toml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "taplo": {
          "command": "taplo",
          "args": [
            "lsp",
            "stdio"
          ],
          "extensionToLanguage": {
            ".toml": "toml"
          }
        }
      }
    },
    {
      "name": "xml-lsp",
      "description": "XML LSP via Eclipse LemMinX; covers DMN, BPMN, SHACL-XML and generic XML/XSD",
      "version": "1.0.0",
      "source": "./plugins/xml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "lemminx": {
          "command": "lemminx",
          "extensionToLanguage": {
            ".xml": "xml",
            ".xsd": "xml",
            ".dmn": "xml",
            ".bpmn": "xml"
          }
        }
      }
    },
    {
      "name": "lean4-lsp",
      "description": "Lean 4 LSP via lake serve",
      "version": "1.0.0",
      "source": "./plugins/lean4-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "lean4": {
          "command": "lake",
          "args": [
            "serve"
          ],
          "extensionToLanguage": {
            ".lean": "lean4"
          }
        }
      }
    },
    {
      "name": "alloy-lsp",
      "description": "Alloy 6 LSP via the `lsp` subcommand of org.alloytools.alloy.dist.jar",
      "version": "1.0.0",
      "source": "./plugins/alloy-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "alloy": {
          "command": "alloy-lsp",
          "extensionToLanguage": {
            ".als": "alloy"
          }
        }
      }
    },
    {
      "name": "dolmen-lsp",
      "description": "Dolmen LSP for SMT-LIB, TPTP, DIMACS, Zipperposition",
      "version": "1.0.0",
      "source": "./plugins/dolmen-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "dolmenls": {
          "command": "dolmen-lsp",
          "extensionToLanguage": {
            ".smt2": "smtlib",
            ".cnf": "dimacs",
            ".icnf": "dimacs",
            ".p": "tptp",
            ".tptp": "tptp",
            ".zf": "zf"
          }
        }
      }
    },
    {
      "name": "egglog-lsp",
      "description": "egglog LSP via hatoo/egglog-language-server",
      "version": "1.0.0",
      "source": "./plugins/egglog-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "egglog": {
          "command": "egglog-lsp",
          "extensionToLanguage": {
            ".egg": "egglog"
          }
        }
      }
    },
    {
      "name": "turtle-lsp",
      "description": "Turtle/RDF LSP via Stardog turtle-language-server",
      "version": "1.0.0",
      "source": "./plugins/turtle-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "turtle": {
          "command": "turtle-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".ttl": "turtle",
            ".nt": "turtle"
          }
        }
      }
    },
    {
      "name": "prolog-lsp",
      "description": "SWI-Prolog LSP via the lsp_server pack (jamesnvc/lsp_server), pinned to v3.16.3",
      "version": "1.0.0",
      "source": "./plugins/prolog-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "prolog": {
          "command": "prolog-lsp",
          "extensionToLanguage": {
            ".pl": "prolog",
            ".pro": "prolog"
          }
        }
      }
    },
    {
      "name": "souffle-lsp",
      "description": "Souffle Datalog LSP via jdaridis/souffle-lsp-plugin",
      "version": "1.0.0",
      "source": "./plugins/souffle-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "souffle": {
          "command": "souffle-lsp",
          "extensionToLanguage": {
            ".dl": "souffle"
          }
        }
      }
    }
  ]
}
